# Production proxy settings
MAKEPAD_PROXY_REPLICAS=1
CATWLK_PROXY_HTTP_PORT=80
CATWLK_PROXY_HTTPS_PORT=443
CATWLK_PROXY_SERVER_NAME=catwlk.example.com
CATWLK_PROXY_CERTS_HOST_PATH=/etc/certs
CATWLK_PROXY_TLS_CERT_FILE=/etc/certs/catwlk.example.com/fullchain.pem
CATWLK_PROXY_TLS_KEY_FILE=/etc/certs/catwlk.example.com/privkey.pem
